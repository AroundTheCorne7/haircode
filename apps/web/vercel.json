{
  "installCommand": "cd ../.. && npm install -g pnpm && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @haircode/engine build && pnpm --filter @haircode/web build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://haircode-api.onrender.com/api/v1/:path*"
    }
  ]
}
