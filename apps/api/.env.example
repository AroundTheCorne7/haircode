# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database (Supabase) ────────────────────────────────────
# Get from: Supabase dashboard → project → "Connect" button → Session pooler URI
# Note: URL-encode special chars in password (/ → %2F, @ → %40)
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Auth ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-secret-here
JWT_REFRESH_SECRET=your-other-64-char-secret-here

# ─── CORS ───────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
APP_URL=https://your-app.vercel.app

# ─── API (self-reference) ───────────────────────────────────
API_URL=https://your-api.onrender.com
